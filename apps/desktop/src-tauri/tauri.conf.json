{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumen",
  "version": "0.1.0",
  "identifier": "dev.lumen.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../web dev --host 127.0.0.1",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --dir ../web build",
    "frontendDist": "../../web/build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lumen",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
